{
  "rewrites": [
    { "source": "/dealer/:slug", "destination": "/dealer.html" },
    { "source": "/dealer/:slug/", "destination": "/dealer.html" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/become-a-dealer", "destination": "/become-a-dealer.html" },
    { "source": "/become-a-dealer/", "destination": "/become-a-dealer.html" },
    { "source": "/partner-preview", "destination": "/partner-preview.html" },
    { "source": "/partner-preview/", "destination": "/partner-preview.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/send-followup",
      "schedule": "0 17 * * *"
    }
  ]
}
